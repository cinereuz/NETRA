{
  "manifest_version": 3,
  "name": "NETRA",
  "version": "1.0.0",
  "description": "Sistem deteksi URL phishing dan judi online berbasis Hybrid Machine Learning dan Crowd Sourcing",

  "permissions": ["activeTab", "storage", "notifications", "tabs"],

  "web_accessible_resources": [
    {
      "resources": ["icons/icon-logo.png", "icons/icon16.png", "icons/icon48.png", "icons/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "host_permissions": ["http://localhost:5000/*", "http://*/*", "https://*/*"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NETRA"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
